# Copy this file to .env and fill in real values. Never commit .env.
#
# AWS credentials themselves are NOT set here — run `aws configure` once on
# this machine and boto3 will pick them up automatically from ~/.aws/credentials.

AWS_REGION=ap-south-1
DYNAMODB_STUDENTS_TABLE=students

# Any long random string. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
AUTH_JWT_SECRET=
