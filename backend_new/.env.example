# Copy this file to .env and fill in real values. Never commit .env.
#
# AWS credentials themselves are NOT set here — run `aws configure` once on
# this machine and boto3 will pick them up automatically from ~/.aws/credentials.

AWS_REGION=ap-south-1
DYNAMODB_STUDENTS_TABLE=students

# Any long random string. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
AUTH_JWT_SECRET=

# RDS (MySQL) connection, used to store course material (file bytes + metadata).
# Get these from the AWS RDS console after creating the instance.
RDS_HOST=
RDS_PORT=3306
RDS_DB_NAME=thapar_connect
RDS_USER=
RDS_PASSWORD=

# Admin login credentials, checked by /auth/admin/login. Defaults match the
# values already hardcoded in Frontend/src/pages/Login.tsx if left unset.
ADMIN_EMAIL=admin@thapar.edu
ADMIN_PASSWORD=qwertyuiop
